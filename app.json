{
  "expo": {
    "name": "Car Shop Service",
    "slug": "ProyectoMoviles",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C1C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIndentifier": "com.tallerautomotriz.proyectosmoviles"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1C1C",
        "softwareKeyboardLayoutMode": "resize"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.tallerautomotriz.proyectomoviles"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78ca04e2-f109-4d0f-9b09-dfe9080655dc"
      }
    },
    "owner": "1mr-robot"
  }
}
